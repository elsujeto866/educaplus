# =============================================================================
# educaplus — environment variables
# Copy this file to .env.local and fill in real values.
# NEVER commit real secrets. This file contains only descriptive placeholders.
# =============================================================================

# Neon (PostgreSQL serverless)
DATABASE_URL=postgresql://your-neon-user:your-neon-password@your-neon-host.neon.tech/your-db-name?sslmode=require

# Clerk authentication
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your-clerk-publishable-key
CLERK_SECRET_KEY=sk_test_your-clerk-secret-key
CLERK_WEBHOOK_SECRET=whsec_placeholder

# Cloudflare Stream
CLOUDFLARE_ACCOUNT_ID=your-cloudflare-account-id
CLOUDFLARE_API_TOKEN=your-cloudflare-api-token

# Anthropic (Claude AI)
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key

# Voyage AI (embeddings)
VOYAGE_API_KEY=pa-your-voyage-api-key
