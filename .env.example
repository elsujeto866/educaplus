# =============================================================================
# Environment Variables -- copy to .env.local and fill in real values.
# Never commit .env.local or any file with real secrets.
# =============================================================================

# -----------------------------------------------------------------------------
# Database (Supabase Postgres)
#
# Get both strings from your Supabase dashboard:
#   Project -> Connect -> Connection string tab
#
# DATABASE_URL  -- Transaction pooler (port 6543, PgBouncer transaction mode).
#   Runtime app (Vercel / serverless). Connects as app_user (NOSUPERUSER
#   NOBYPASSRLS) so RLS is enforced. Pooler username: app_user.<project-ref>
#   Example: postgresql://app_user.abcdefghijkl:PASSWORD@aws-0-us-east-1.pooler.supabase.com:6543/postgres
#
# DIRECT_DATABASE_URL -- Direct connection (port 5432, no PgBouncer).
#   For pnpm db:migrate and pnpm db:rls only. Username: app_user (no suffix).
#   Example: postgresql://app_user:PASSWORD@db.abcdefghijkl.supabase.co:5432/postgres
#
# RLS-PROD-01 (CRITICAL): MUST use app_user, NOT postgres/owner.
#   Superuser silently bypasses RLS -- leaks data across academies.
# Percent-encode special chars in password (%40 for @, etc.).
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://app_user.YOUR_PROJECT_REF:YOUR_PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres
DIRECT_DATABASE_URL=postgresql://app_user:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres

# -----------------------------------------------------------------------------
# Auth (Clerk) -- Dashboard -> Your application -> API Keys
#   NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY: pk_live_... (build-time, client-safe)
#   CLERK_SECRET_KEY:                  sk_live_... (server-side only)
#   CLERK_WEBHOOK_SECRET:              whsec_...  (Webhooks -> endpoint -> Signing Secret)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_live_YOUR_PUBLISHABLE_KEY
CLERK_SECRET_KEY=sk_live_YOUR_SECRET_KEY
CLERK_WEBHOOK_SECRET=whsec_YOUR_SIGNING_SECRET

# -----------------------------------------------------------------------------
# Supabase API (OPTIONAL -- not required for Postgres-only usage)
# Reserved for future Supabase Storage integration. Leave blank until needed.
#   SUPABASE_URL:             Dashboard -> Project Settings -> API -> Project URL
#   SUPABASE_PUBLISHABLE_KEY: anon key (sb_publishable_...) -- client-safe
#   SUPABASE_SECRET_KEY:      service_role key (sb_secret_...) -- server-side only
# -----------------------------------------------------------------------------
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_YOUR_KEY
SUPABASE_SECRET_KEY=sb_secret_YOUR_KEY

# -----------------------------------------------------------------------------
# Video (Cloudflare Stream) -- Dashboard -> Stream -> API Tokens
# -----------------------------------------------------------------------------
CLOUDFLARE_ACCOUNT_ID=YOUR_CLOUDFLARE_ACCOUNT_ID
CLOUDFLARE_API_TOKEN=YOUR_CLOUDFLARE_API_TOKEN

# -----------------------------------------------------------------------------
# AI
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-YOUR_KEY
VOYAGE_API_KEY=pa-YOUR_VOYAGE_KEY
