    "eslint-plugin-boundaries": "^6.0.2",
    "jsdom": "^29.1.1",
    "postgres": "^3.4.9",
    "prettier": "^3.9.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.9"
